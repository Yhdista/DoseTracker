<?xml version="1.0" encoding="utf-8"?><!--
   Pre-API-31 Auto Backup rules. The medication database and settings ARE backed up
   (encrypted with the device lockscreen secret since API 28) so users keep their dose
   history on a new device. Debug log files contain the same medication data in plain
   text and must never leave the device.
-->
<full-backup-content>
    <exclude domain="external" path="debug_log" />
</full-backup-content>
