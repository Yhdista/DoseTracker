<?xml version="1.0" encoding="utf-8"?><!--
   API 31+ rules. Database and settings are included in both cloud backup and
   device-to-device transfer; plain-text debug logs are excluded from both.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="external" path="debug_log" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="external" path="debug_log" />
    </device-transfer>
</data-extraction-rules>
